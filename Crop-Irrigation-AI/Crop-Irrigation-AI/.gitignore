# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# ── Environment / secrets ──────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Data (large/binary — track via DVC or cloud storage instead) ──────────
data/satellite_data/*
!data/satellite_data/.gitkeep
data/weather_data/*.nc
data/weather_data/*.grib
*.SAFE/
*.zip

# ── Model artifacts ─────────────────────────────────────────────────────────
models/saved/*.pkl
models/saved/*.pt
models/saved/*.h5
*.joblib

# ── Outputs (regenerated by pipeline) ───────────────────────────────────────
outputs/*.tif
outputs/reports/*.csv
outputs/reports/*.json
outputs/reports/*.geojson
!outputs/.gitkeep
!outputs/reports/.gitkeep

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*-checkpoint.ipynb

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store

# ── Testing / coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Streamlit ───────────────────────────────────────────────────────────────
.streamlit/secrets.toml
