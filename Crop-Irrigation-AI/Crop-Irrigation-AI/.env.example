# ─────────────────────────────────────────────────────────────────────────────
# Crop-Irrigation-AI — Environment Configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sentinel Copernicus Hub (satellite data download) ──────────────────────
SENTINELSAT_USER=
SENTINELSAT_PASS=

# ── Weather APIs ─────────────────────────────────────────────────────────────
OWM_API_KEY=
# Copernicus Climate Data Store (CDS) API key for ERA5 — see ~/.cdsapirc
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/crop_irrigation
REDIS_URL=redis://localhost:6379/0

# ── API server ─────────────────────────────────────────────────────────────
DEBUG=false
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── SMS / Alerts (optional — Twilio or local SMS gateway) ──────────────────
SMS_PROVIDER_API_KEY=
SMS_SENDER_ID=CROPAI
